  "schema_version": "v2_source_profile_summary_v1",
  "source_id": "{{ source_profile.source_id }}",
  "semantic_summary": "one compact diagnosis",
  "strengths": ["short strength"],
  "weaknesses": ["short weakness"],
  "best_use": "shape|trend|privacy|utility|balanced|diverse"
}
